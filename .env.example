# このファイルを .env にコピーして使う:  cp .env.example .env
# ※ .env は .gitignore 済み。実トークンは .env にのみ記入（配布・コミットしない）。

# --- 認証（どれか1つ / 未設定でもコンテナ内 `claude /login` で可） ---

# 推奨: サブスク(Pro/Max)用トークン。ホストで `claude setup-token` で取得
# CLAUDE_CODE_OAUTH_TOKEN=<paste-your-setup-token-here>

# API課金で使う場合のみ（サブスクなら設定しない）
# ANTHROPIC_API_KEY=<paste-your-api-key-here>

# --- 起動ディレクトリ（= マウント先） ---
# Claude を起動したいプロジェクトのホスト側パス。これが /workspace にマウントされ、
# Claude はそのフォルダ内で起動する。パスは / 区切り、スペース/日本語OK（クォート不要）。
#   Windows 例:  PROJECT_PATH=C:/Users/yourname/Projects/my-app
#   Mac/Linux例: PROJECT_PATH=/Users/yourname/Projects/my-app
# 未設定なら同梱の ./workspace が使われる。
# PROJECT_PATH=

# --- プラグイン取得元（git / private 対応） ---
# 起動毎にここから clone/pull して最新を取り込む。未設定なら同梱版を使用。
# PLUGIN_REPO_URL=https://github.com/yourorg/yoken-teigi-kun-ver-opus.git
# PLUGIN_REPO_REF=main
# private リポジトリ用のアクセストークン(PAT)。repo読み取り権限があればよい
# GITHUB_TOKEN=<paste-your-github-pat-here>

# --- 任意 ---
# YOKEN_FIREWALL=on
# ALLOWED_DOMAINS=api.anthropic.com registry.npmjs.org pypi.org files.pythonhosted.org github.com

# --- git 進捗管理（コンテナ内で commit/push するとき）---
# commit の名義。push するには上の GITHUB_TOKEN に書き込み権限(repo)が必要。
# GIT_USER_NAME=your-name
# GIT_USER_EMAIL=you@example.com

# ブラウザで覗く開発ポート（カンマ区切り）。compose の ports: と揃える
# DEV_PORTS=3000

# ホスト側3000が埋まってる時は別番号に（ブラウザは http://localhost:<この番号>）
# HOST_PORT=3001
